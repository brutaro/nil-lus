        { url: "https://static.wixstatic.com/media/e8911b_35edb3121c5f484d934839f88b185e8d~mv2.jpg/v1/fit/w_960,h_722,q_90,enc_avif,quality_auto/e8911b_35edb3121c5f484d934839f88b185e8d~mv2.jpg", title: "Live Performance" },
