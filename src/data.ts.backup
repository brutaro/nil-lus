    literature: {
      heading: "Literary Works & Poetry",
      subheading: "Where prose meets melody and written words find their sound.",
      romanceTitle: "The Voyage to the Other Side (A Viagem para o Outro Lado)",
      romanceDesc: "A groundbreaking novel accompanied by an original instrumental soundtrack. Released in 2010 and currently in its 3rd successful edition in Brazil. An esoteric and modern narrative.",
      dadivanteTitle: "Dadivante",
      dadivanteDesc: "A book of profound reflections and aphorisms structured as a calendar of daily meditations. Enriched with exclusive concept photography by renowned German photographer Sabine Geilke.",
      poetosferaTitle: "Poetosfera",
      poetosferaDesc: "A collection of personal poems detailing love, human distance, the passage of autumn, and the secrets residing inside the author's soul.",
      homageHeading: "Tribute: O Baú de Lygia (Lygia's Chest)",
      homageDesc: "My sincere tribute to a close friend since the 90s, whom I met at a literary forum in Lisbon: the great dame of Brazilian literature, Lygia Fagundes Telles. Glorious, brilliant, and a woman that represents multiple generations.",
      poemLines: [
        "\"Ah, if I could tidy myself up from within / Everything moves in drawers\" slowly and without fear",
        "Arrange things, scratch destiny, dye my hair",
        "And then sweep from the floor the autumn leaves of time",
        "In my chest I still keep loves, a thousand secrets",
        "At the very bottom, it's lined with a mirror",
        "Where, innocent as a child, I still live and see myself",
        "Running through fields between games and toys",
        "I smile with tears in my eyes and still remember",
        "I reread letters of loves that departed in despair",
        "Even if I had dreamed one day in another way",
        "These are now old desires, all outside of myself",
        "An old dress, a doll, a ring, a key chain",
        "Rags and books, portraits, maps, first drawings",
        "Everything is nostalgia like a car with rear taillights",
        "My heart is a clock spinning backwards inside my chest."
      ],
      teatroTitle: "Soundtracks - Theater & Cinema",
      teatroDesc: "Throughout his broad career, Nil Lus composed highly acclaimed sound arrangements for deep intellectual plays and international films.",
      teatroTracks: [
        "Tambores Na Noite (Bertolt Brecht)",
        "Esperando Godot (Samuel Beckett)",
        "Bella Ciao (Alberto Abreu)",
        "O Mercado De Escravos (Ana Barradas)",
        "O Último Dia de Florbela Espanca",
        "Lux (Maria Clara Machado)",
        "Ninguém Reparou Na Primavera (Maria Lúcia Godoy)",
        "King - I Have a Dream (Martin Luther King)"
      ],
      cinemaTracks: [
        "Amal Hamburg (Hanni Bergesch Wolf, Germany)",
        "O Caminho de Volta (Aberto Cabral, Switzerland)",
        "The Quest for Love (Georgi Rossi, Netherlands)"
      ]
    },
    handball: {
      heading: "Handball Cannon: From Courts to the Stage",
      subheading: "The unique journey of an elite athlete who represented Brazil on courts and won European stages.",
      desc1: "A sports highlight of the 1980s, Nilton Cruz (his birth name) was part of the Brazilian National Handball Team from 1980 to 1985, crowned National and South American Champion.",
      desc2: "Recognized for the massive power and precision of his shots, he was nicknamed 'Canhão' (Handball Cannon). He studied Physical Education at UFMG and traveled the world representing Brazil before deciding to focus fully on his acoustic guitar on the streets of New York, Portugal, and Germany.",
      poemTitle: "Athlete Forever (Atleta Para Sempre)",
      poemLines: [
        "Being an athlete is being a poet",
        "With hands, arms, or legs",
        "A medal is an open page",
        "From the book of your odyssey",
        "Victory and defeat?! In the end, none of this matters",
        "They are keys of gold or brass that open the same door:",
        "Of nobility and glory that sport devotes to us",
        "From violence it protects us and from drugs it saves us",
        "Life is a ball that rolls and rolls straight ahead",
        "The champion and the loser, are heads and tails of the same coin",
        "The difference lies in the moment of friendship, God help us",
        "For friends are like houses carrying the address of our soul."
      ],
      dedication: "“I want to dedicate this song to all athletes who discovered that the most valuable of medals we carry on our chests is the value of friendship, which makes us all victorious. There is no loser when you make a friend in sports!”"
    },
