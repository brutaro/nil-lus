        { url: "https://static.wixstatic.com/media/e8911b_27f69d73cfbe440497f04b3c5c848a52~mv2.jpg/v1/fit/w_718,h_960,q_90,enc_avif,quality_auto/e8911b_27f69d73cfbe440497f04b3c5c848a52~mv2.jpg", title: "Recording Studio" },
